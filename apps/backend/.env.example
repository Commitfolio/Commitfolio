GITHUB_CLIENT_ID=your-github-app-client-id
GITHUB_CLIENT_SECRET=your-github-app-client-secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/v1/auth/github/callback
# OAuth App private repository listing requires the broad "repo" scope.
# Keep this visible until Commitfolio moves to tighter GitHub App permissions.
GITHUB_SCOPE=read:user repo read:org
FRONTEND_APP_URL=http://localhost:5173
BACKEND_CORS_ORIGIN=http://localhost:5173
SESSION_SECRET=replace-this-in-real-use
# For split-domain preview/prod frontend/backend deployments, use SameSite=None and Secure=true.
# Keep defaults as lax/false for local localhost development.
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=false
DATABASE_URL=sqlite:///./commitfolio.db

# Optional Stage 7 result quality enhancement. Leave empty to use deterministic fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=8
LOG_LEVEL=INFO
